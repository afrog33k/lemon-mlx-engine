# This patch adds group_size=256 support to MLX QMV kernels.
# Must be applied AFTER mlx-rocm-gfx1151-disable-qmv-tiled.patch and
# mlx-rocm-gfx1151-qmv-cols64.patch.
diff --git a/mlx/backend/rocm/quantized/qmm.hip b/mlx/backend/rocm/quantized/qmm.hip
index e6758519..12345678 100644
